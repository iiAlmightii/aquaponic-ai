# =============================================================================
# AquaponicAI — Environment Variables Template
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AquaponicAI
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ── Security (CHANGE THESE IN PRODUCTION) ─────────────────────────────────────
SECRET_KEY=GENERATE_WITH_openssl_rand_-hex_32
JWT_SECRET_KEY=GENERATE_WITH_openssl_rand_-hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql+asyncpg://aquaponic:changeme_secure_password@postgres:5432/aquaponic_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost","http://127.0.0.1:3000","http://127.0.0.1:3001"]

# ── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
DEFAULT_LLM_PROVIDER=anthropic    # anthropic | openai | local
# Optional but recommended for faster Whisper model download and higher HF limits
# HF_TOKEN=hf_xxx

# ── Speech-to-Text ─────────────────────────────────────────────────────────────
STT_PROVIDER=whisper              # whisper | google | deepgram
FASTER_WHISPER_MODEL=large-v3
FASTER_WHISPER_DEVICE=cuda        # cpu | cuda
FASTER_WHISPER_COMPUTE_TYPE=int8_float16  # int8 | int8_float16 | float16

# ── Object Storage ────────────────────────────────────────────────────────────
STORAGE_BACKEND=local             # local | s3
LOCAL_STORAGE_PATH=./storage
# S3_BUCKET=your-bucket-name
# S3_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── External APIs ─────────────────────────────────────────────────────────────
WEATHER_API_KEY=your_openweathermap_key
MARKET_API_KEY=your_commodity_price_api_key
# ── data.gov.in API Key (for live mandi crop prices) ─────────────────────────
# Without this key the app uses hardcoded India benchmark prices (Agmarknet FY24-25 averages).
# Live prices are more accurate and location-specific.
#
# To get a FREE API key (takes 2 minutes):
#   1. Go to https://data.gov.in → Register
#   2. Log in → My Dashboard → API Keys → Generate New Key
#   3. Paste it below
DATA_GOV_IN_API_KEY=
LAND_MARKET_ENABLE_REALTIME=true
LAND_MARKET_HTTP_TIMEOUT=6
LAND_MARKET_MAX_RETRIES=2
LAND_MARKET_CACHE_TTL_MINUTES=360

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1

# ── Supabase Integration ──────────────────────────────────────────────────────
# To use Supabase as your database (recommended for viewing data on the web):
# 1. Create a project at https://supabase.com
# 2. Go to Settings > Database → copy the "URI" connection string (Transaction mode, port 6543)
# 3. Replace DATABASE_URL below with:
#    DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
# 4. In the Supabase SQL Editor, run the contents of infra/schema.sql to create tables
# 5. Use the Supabase dashboard to view and query your data in real-time
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Supabase direct PostgreSQL connection (used by Looker Studio connector)
# Find these in Supabase → Settings → Database → Connection string (Direct)
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres

# ── Looker Studio Integration ─────────────────────────────────────────────────
# Pre-built Looker Studio report connected to your Supabase PostgreSQL.
# Setup steps:
#   1. Open lookerstudio.google.com → Create report → Add data → PostgreSQL connector
#   2. Enter SUPABASE_DB_HOST, port 5432, database postgres, SSL required
#   3. Connect to sessions / session_answers / financial_plans tables
#   4. Add a "Filter control" widget with field = session_id
#   5. Publish → copy the 32-char report ID from the URL
# Leave blank to see in-app setup instructions instead of a broken link.
LOOKER_STUDIO_REPORT_ID=
LOOKER_STUDIO_PAGE_ID=p_page1

# ── Google Sheets Sync (Finance Planning) ──────────────────────────────────────
# Enable the optional Sheets sync UI/polling in the frontend:
VITE_GOOGLE_SHEETS_ENABLED=true

# Google Sheets credentials and spreadsheet id (service-account based).
# Set GOOGLE_SHEETS_SPREADSHEET_ID to the target spreadsheet.
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Option A (recommended): full service account JSON in one env var.
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Option B: split env vars.
# GOOGLE_SHEETS_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com
# GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"


# ── Evaluation Pipeline ───────────────────────────────────────────────────────
# Set EVAL_MODE=true to register /api/v1/eval/* endpoints (audio collection + WER pipeline).
# SARVAM_API_KEY is only required when EVAL_MODE=true.
# Get a free key at https://dashboard.sarvam.ai (500 min/month free tier).
EVAL_MODE=false
SARVAM_API_KEY=your_sarvam_key_here
